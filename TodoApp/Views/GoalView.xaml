<UserControl x:Class="TodoApp.Views.GoalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:GoalViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource AppBackground}">

    <UserControl.Resources>

        <!-- Glossy animated progress bar -->
        <Style x:Key="GoalProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="{DynamicResource DividerBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <!-- Track clips fill to rounded corners -->
                        <Border x:Name="PART_Track" CornerRadius="7" ClipToBounds="True"
                                Background="{TemplateBinding Background}">
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Opacity="0.55"/>
                                </Border.Effect>
                                <!-- Glossy white highlight -->
                                <Border Margin="0,0,0,7" Opacity="0.38">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="White" Offset="0"/>
                                            <GradientStop Color="Transparent" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Green check-in button -->
        <Style x:Key="CheckTodayBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="#4CAF50"/>
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="10,5"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource DividerBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="24,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="Flag" Width="22" Height="22"
                                             Foreground="{DynamicResource PrimaryBrush}"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Nav_Goals}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource Primary50Brush}"
                            CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding GoalCount}"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"/>
                    </Border>
                </StackPanel>

                <Button HorizontalAlignment="Right"
                        Style="{DynamicResource MaterialDesignRaisedButton}"
                        Background="{DynamicResource PrimaryBrush}"
                        Command="{Binding ShowAddFormCommand}"
                        Padding="14,6"
                        materialDesign:ButtonAssist.CornerRadius="8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Goal_AddNew}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── Add / Edit form ────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="24,16">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsAddFormVisible}"  Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsEditFormVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>

            <StackPanel>
                <!-- Form title -->
                <TextBlock FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text" Value="{DynamicResource Goal_AddFormTitle}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditFormVisible}" Value="True">
                                    <Setter Property="Text" Value="{DynamicResource Goal_EditFormTitle}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Title + Days + Buttons row -->
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding NewTitle, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource RoundedTextBoxStyle}"
                             materialDesign:HintAssist.Hint="{DynamicResource Goal_TitleHint}"/>

                    <!-- Days input -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBox Width="60"
                                 Text="{Binding NewTotalDays, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{DynamicResource RoundedTextBoxStyle}"
                                 FontFamily="Consolas"
                                 materialDesign:HintAssist.Hint="30"/>
                        <TextBlock Text="{DynamicResource Goal_Days}"
                                   VerticalAlignment="Center" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="6,0,0,0"/>
                    </StackPanel>

                    <!-- Cancel -->
                    <Button Grid.Column="4"
                            Content="{DynamicResource Btn_Cancel}"
                            Padding="12,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                <Setter Property="Command" Value="{Binding CancelAddCommand}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditFormVisible}" Value="True">
                                        <Setter Property="Command" Value="{Binding CancelEditCommand}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Save -->
                    <Button Grid.Column="6"
                            Content="{DynamicResource Btn_Save}"
                            Padding="16,8">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                <Setter Property="Command" Value="{Binding SaveNewGoalCommand}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsEditFormVisible}" Value="True">
                                        <Setter Property="Command" Value="{Binding SaveEditCommand}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

                <!-- Description -->
                <TextBox Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource RoundedTextBoxStyle}"
                         materialDesign:HintAssist.Hint="{DynamicResource Goal_DescHint}"
                         AcceptsReturn="True" Height="54" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Border>

        <!-- ── Goal cards ─────────────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding GoalCount}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="FlagOutline" Width="64" Height="64"
                                         Foreground="{DynamicResource DividerBrush}"
                                         HorizontalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Goal_Empty}"
                           FontSize="16" FontWeight="Medium"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,12,0,6"/>
                <TextBlock Text="{DynamicResource Goal_EmptyHint}"
                           FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Full-width cards, stacked vertically -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,16">
                <ItemsControl ItemsSource="{Binding Goals}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Vertical"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,12"
                                    CornerRadius="12"
                                    Background="{DynamicResource SurfaceBrush}"
                                    Padding="18,16">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.09"
                                                      BlurRadius="14" ShadowDepth="3" Direction="270"/>
                                </Border.Effect>

                                <StackPanel>
                                    <!-- Title row -->
                                    <Grid Margin="0,0,0,6">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                    Margin="0,0,72,0">
                                            <materialDesign:PackIcon Kind="Flag" Width="15" Height="15"
                                                                     Foreground="{DynamicResource PrimaryBrush}"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Goal.Title}"
                                                       FontSize="14" FontWeight="Bold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                                    VerticalAlignment="Center">
                                            <!-- Completed badge -->
                                            <Border CornerRadius="5" Padding="5,2" Margin="0,0,4,0"
                                                    Background="#1A4CAF50">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Check" Width="11" Height="11"
                                                                             Foreground="#4CAF50"
                                                                             VerticalAlignment="Center"/>
                                                    <TextBlock Text="{DynamicResource Goal_Done}"
                                                               FontSize="10" Foreground="#4CAF50"
                                                               Margin="3,0,0,0" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>

                                            <Button Style="{DynamicResource IconButtonStyle}"
                                                    Width="28" Height="28"
                                                    Command="{Binding DataContext.StartEditCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Pencil" Width="13" Height="13"
                                                                         Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            </Button>
                                            <Button Style="{DynamicResource IconButtonStyle}"
                                                    Width="28" Height="28"
                                                    Command="{Binding DataContext.DeleteGoalCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Delete" Width="13" Height="13"
                                                                         Foreground="{DynamicResource ErrorBrush}"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Description -->
                                    <TextBlock Text="{Binding Goal.Description}"
                                               FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="36" TextWrapping="Wrap"
                                               Margin="0,0,0,12">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Goal.Description}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Progress bar + % -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar Grid.Column="0"
                                                     Maximum="1"
                                                     Style="{StaticResource GoalProgressBarStyle}">
                                            <ProgressBar.Value>
                                                <Binding Path="ProgressRatio"/>
                                            </ProgressBar.Value>
                                            <ProgressBar.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Value"
                                                                             From="0" Duration="0:0:0.9">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut"/>
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </ProgressBar.Triggers>
                                        </ProgressBar>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ProgressPercent}"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="{DynamicResource PrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Days progress + Check Today button -->
                                    <Grid>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="CalendarCheck" Width="13" Height="13"
                                                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                                                     VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding DaysText}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       Margin="4,0,0,0" VerticalAlignment="Center"/>
                                        </StackPanel>

                                        <Button HorizontalAlignment="Right"
                                                Style="{StaticResource CheckTodayBtnStyle}"
                                                IsEnabled="{Binding CanCheckToday}"
                                                Command="{Binding DataContext.CheckTodayCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="CheckCircle" Width="13" Height="13"
                                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="{DynamicResource Goal_CheckToday}"
                                                           FontSize="11" Margin="4,0,0,0"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ── Celebration overlay ────────────────────────────────────────── -->
        <Grid Grid.Row="0" Grid.RowSpan="3" Panel.ZIndex="99">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ShowCelebration}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Dim backdrop -->
            <Border Background="#AA000000"/>

            <!-- Confetti canvas (code-behind populates this) -->
            <Canvas x:Name="ConfettiCanvas" IsHitTestVisible="False"/>

            <!-- Modal card -->
            <Border MaxWidth="420" HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="16" Padding="36,30"
                    Background="{DynamicResource SurfaceBrush}">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.35" BlurRadius="40" ShadowDepth="10"/>
                </Border.Effect>
                <StackPanel HorizontalAlignment="Center">
                    <!-- Trophy circle -->
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="{DynamicResource Primary50Brush}"
                            HorizontalAlignment="Center" Margin="0,0,0,18">
                        <materialDesign:PackIcon Kind="Trophy" Width="40" Height="40"
                                                 Foreground="{DynamicResource PrimaryBrush}"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="{DynamicResource Goal_CelebTitle}"
                               FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,8"/>

                    <TextBlock Text="{Binding CelebrationGoalTitle}"
                               FontSize="15" FontWeight="Medium"
                               Foreground="{DynamicResource PrimaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,8"/>

                    <TextBlock Text="{DynamicResource Goal_CelebSubtitle}"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="0,0,0,26"/>

                    <Button Content="{DynamicResource Goal_CelebClose}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding CloseCelebrationCommand}"
                            HorizontalAlignment="Center"
                            Padding="32,11" FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
