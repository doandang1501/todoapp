<UserControl x:Class="TodoApp.Views.KanbanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:KanbanViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource AppBackground}">

    <UserControl.Resources>

        <!-- Column header accent colours -->
        <SolidColorBrush x:Key="ColTodoColor"       Color="#5C6BC0"/>
        <SolidColorBrush x:Key="ColInProgressColor" Color="#FF9800"/>
        <SolidColorBrush x:Key="ColDoneColor"       Color="#4CAF50"/>

        <!-- Priority bar colours -->
        <SolidColorBrush x:Key="PrioLowColor"      Color="#4CAF50"/>
        <SolidColorBrush x:Key="PrioMediumColor"   Color="#FF9800"/>
        <SolidColorBrush x:Key="PrioHighColor"     Color="#F44336"/>
        <SolidColorBrush x:Key="PrioCriticalColor" Color="#9C27B0"/>

        <!-- Drag-over highlight style for a column -->
        <Style x:Key="DropColumnStyle" TargetType="Border">
            <Setter Property="Background"     Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource DividerBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius"   Value="10"/>
        </Style>

        <!-- Compact Kanban card template (reused by all three columns) -->
        <DataTemplate x:Key="KanbanCardTemplate" DataType="{x:Type vm:TaskRowViewModel}">
            <Border x:Name="CardBorder"
                    Margin="0,0,0,6"
                    CornerRadius="8"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource DividerBrush}"
                    Cursor="SizeAll"
                    MouseMove="OnCardMouseMove"
                    MouseLeftButtonDown="OnCardMouseDown"
                    Tag="{Binding}">

                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background"  Value="{DynamicResource SurfaceBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                <Setter Property="Opacity" Value="0.6"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsUrgent}" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Priority colour bar -->
                    <Border Grid.Column="0" CornerRadius="8,0,0,8">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource PrioMediumColor}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Priority}" Value="Low">
                                        <Setter Property="Background" Value="{StaticResource PrioLowColor}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Priority}" Value="High">
                                        <Setter Property="Background" Value="{StaticResource PrioHighColor}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Priority}" Value="Critical">
                                        <Setter Property="Background" Value="{StaticResource PrioCriticalColor}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>

                    <!-- Card body -->
                    <StackPanel Grid.Column="1" Margin="10,8,4,8">

                        <!-- Title -->
                        <TextBlock Text="{Binding Title}"
                                   FontSize="13" FontWeight="Medium"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- Deadline badge -->
                        <Border CornerRadius="4" Padding="5,2" Margin="0,5,0,0"
                                HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource Primary50Brush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DeadlineRelative}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Clock" Width="11" Height="11"
                                                         VerticalAlignment="Center">
                                    <materialDesign:PackIcon.Style>
                                        <Style TargetType="materialDesign:PackIcon">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </materialDesign:PackIcon.Style>
                                </materialDesign:PackIcon>
                                <TextBlock Text="{Binding DeadlineRelative}"
                                           FontSize="10" Margin="3,0,0,0"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Tag chips -->
                        <ItemsControl ItemsSource="{Binding Tags}" Margin="0,4,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Primary100Brush}"
                                            CornerRadius="4" Padding="5,1" Margin="0,0,3,2">
                                        <TextBlock Text="{Binding}" FontSize="10"
                                                   Foreground="{DynamicResource PrimaryDarkBrush}"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Subtask progress -->
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSubTasks}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <materialDesign:PackIcon Kind="CheckboxMultipleOutline"
                                                     Width="11" Height="11"
                                                     Foreground="{DynamicResource TextSecondaryBrush}"
                                                     VerticalAlignment="Center"/>
                            <TextBlock FontSize="10" Margin="3,0,0,0"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="{Binding SubTaskDone, Mode=OneWay}"/>
                                <Run Text="/"/>
                                <Run Text="{Binding SubTaskCount, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                    </StackPanel>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="0,4,4,4">
                        <Button Style="{DynamicResource IconButtonStyle}"
                                Width="28" Height="28" ToolTip="Edit"
                                Command="{Binding DataContext.EditTaskCommand,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14"
                                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                        </Button>
                        <Button Style="{DynamicResource IconButtonStyle}"
                                Width="28" Height="28" ToolTip="Delete"
                                Command="{Binding DataContext.DeleteTaskCommand,
                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}">
                            <materialDesign:PackIcon Kind="Delete" Width="14" Height="14"
                                                     Foreground="{DynamicResource ErrorBrush}"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header bar -->
            <RowDefinition Height="*"/>     <!-- Columns -->
        </Grid.RowDefinitions>

        <!-- â"€â"€ Top header â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="24,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ViewColumn" Width="22" Height="22"
                                             Foreground="{DynamicResource PrimaryBrush}"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Page_Kanban}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="16,0,0,0" VerticalAlignment="Center">
                        <Run Text="{Binding TodoCount, Mode=OneWay}"/>
                        <Run Text="{DynamicResource Kanban_SummaryTodo}"/>
                        <Run Text="{Binding InProgressCount, Mode=OneWay}"/>
                        <Run Text="{DynamicResource Kanban_SummaryInProgress}"/>
                        <Run Text="{Binding DoneCount, Mode=OneWay}"/>
                        <Run Text="{DynamicResource Kanban_SummaryDone}"/>
                    </TextBlock>
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding AddTaskCommand}"
                        CommandParameter="{x:Null}"
                        Padding="14,7">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Task_NewTask}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- â"€â"€ Three columns â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ -->
        <Grid Grid.Row="1" Margin="16,16,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- â"€â"€ To Do â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Column header -->
                <Border Grid.Row="0" CornerRadius="8,8,0,0" Padding="14,10">
                    <Border.Background>
                        <SolidColorBrush Color="#5C6BC0" Opacity="0.12"/>
                    </Border.Background>
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="10" Height="10" CornerRadius="5"
                                    Background="{StaticResource ColTodoColor}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Kanban_Todo}"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource ColTodoColor}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right"
                                Background="{StaticResource ColTodoColor}"
                                CornerRadius="10" Padding="8,2">
                            <TextBlock Text="{Binding TodoCount}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Drop zone for Todo (click empty area to add task) -->
                <Border Grid.Row="1"
                        x:Name="TodoDropZone"
                        Tag="Todo"
                        AllowDrop="True"
                        DragOver="OnColumnDragOver"
                        DragLeave="OnColumnDragLeave"
                        Drop="OnColumnDrop"
                        MouseLeftButtonUp="OnDropZoneMouseUp"
                        BorderThickness="1,0,1,1"
                        BorderBrush="{DynamicResource DividerBrush}"
                        Background="{DynamicResource AppBackground}"
                        CornerRadius="0,0,8,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,3,0">
                        <ItemsControl ItemsSource="{Binding TodoItems}"
                                      Margin="10,10,10,10"
                                      ItemTemplate="{StaticResource KanbanCardTemplate}"/>
                    </ScrollViewer>
                </Border>

            </Grid>

            <!-- â"€â"€ In Progress â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="8,8,0,0" Padding="14,10">
                    <Border.Background>
                        <SolidColorBrush Color="#FF9800" Opacity="0.12"/>
                    </Border.Background>
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="10" Height="10" CornerRadius="5"
                                    Background="{StaticResource ColInProgressColor}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Kanban_InProgress}"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource ColInProgressColor}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right"
                                Background="{StaticResource ColInProgressColor}"
                                CornerRadius="10" Padding="8,2">
                            <TextBlock Text="{Binding InProgressCount}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        x:Name="InProgressDropZone"
                        Tag="InProgress"
                        AllowDrop="True"
                        DragOver="OnColumnDragOver"
                        DragLeave="OnColumnDragLeave"
                        Drop="OnColumnDrop"
                        MouseLeftButtonUp="OnDropZoneMouseUp"
                        BorderThickness="1,0,1,1"
                        BorderBrush="{DynamicResource DividerBrush}"
                        Background="{DynamicResource AppBackground}"
                        CornerRadius="0,0,8,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,3,0">
                        <ItemsControl ItemsSource="{Binding InProgressItems}"
                                      Margin="10,10,10,10"
                                      ItemTemplate="{StaticResource KanbanCardTemplate}"/>
                    </ScrollViewer>
                </Border>

            </Grid>

            <!-- â"€â"€ Done â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€ -->
            <Grid Grid.Column="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="8,8,0,0" Padding="14,10">
                    <Border.Background>
                        <SolidColorBrush Color="#4CAF50" Opacity="0.12"/>
                    </Border.Background>
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="10" Height="10" CornerRadius="5"
                                    Background="{StaticResource ColDoneColor}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Kanban_Done}"
                                       FontSize="12" FontWeight="Bold"
                                       Foreground="{StaticResource ColDoneColor}"
                                       Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <Border HorizontalAlignment="Right"
                                Background="{StaticResource ColDoneColor}"
                                CornerRadius="10" Padding="8,2">
                            <TextBlock Text="{Binding DoneCount}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="White"/>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        x:Name="DoneDropZone"
                        Tag="Done"
                        AllowDrop="True"
                        DragOver="OnColumnDragOver"
                        DragLeave="OnColumnDragLeave"
                        Drop="OnColumnDrop"
                        MouseLeftButtonUp="OnDropZoneMouseUp"
                        BorderThickness="1,0,1,1"
                        BorderBrush="{DynamicResource DividerBrush}"
                        Background="{DynamicResource AppBackground}"
                        CornerRadius="0,0,8,8">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,3,0">
                        <ItemsControl ItemsSource="{Binding DoneItems}"
                                      Margin="10,10,10,10"
                                      ItemTemplate="{StaticResource KanbanCardTemplate}"/>
                    </ScrollViewer>
                </Border>

            </Grid>

        </Grid>

        <!-- Busy overlay -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#88FFFFFF"/>
            <ProgressBar Width="40" Height="40" IsIndeterminate="True"
                         VerticalAlignment="Center" HorizontalAlignment="Center"
                         Foreground="{DynamicResource PrimaryBrush}"/>
        </Grid>

    </Grid>
</UserControl>

