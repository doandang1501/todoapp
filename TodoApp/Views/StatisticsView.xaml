<UserControl x:Class="TodoApp.Views.StatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:StatisticsViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource AppBackground}">

    <UserControl.Resources>

        <!-- Summary card style -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="CornerRadius"    Value="10"/>
            <Setter Property="Padding"         Value="20,16"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource DividerBrush}"/>
        </Style>

        <Style x:Key="StatValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="32"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>

        <Style x:Key="StatLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,4,0,0"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="24,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="ChartBar" Width="22" Height="22"
                                             Foreground="{DynamicResource PrimaryBrush}"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Page_Statistics}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <Button HorizontalAlignment="Right"
                        Style="{DynamicResource GhostButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        Padding="12,7">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" Width="16" Height="16"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Btn_Refresh}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── Scrollable content ─────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="20,16,20,24">

                <!-- ── Summary cards row 1 ─────────────────────────────────── -->
                <UniformGrid Rows="1" Margin="0,0,0,12">
                    <UniformGrid.Resources>
                        <Thickness x:Key="CardMargin">0,0,12,0</Thickness>
                    </UniformGrid.Resources>

                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="{Binding TotalActive}"   Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="{DynamicResource Stat_ActiveTasks}" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="{Binding CompletedToday}" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="{DynamicResource Stat_CompletedToday}" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="{Binding OverdueCount}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource StatValueStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding OverdueCount}" Value="0">
                                                <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{DynamicResource Stat_Overdue}" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding DueSoonCount}" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="{DynamicResource Stat_DueSoon}" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ── Summary cards row 2 ─────────────────────────────────── -->
                <UniformGrid Rows="1" Margin="0,0,0,20">
                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding CurrentStreak}" Style="{StaticResource StatValueStyle}"/>
                                <materialDesign:PackIcon Kind="Fire" Width="24" Height="24"
                                                         Foreground="#FF9800"
                                                         VerticalAlignment="Bottom"
                                                         Margin="6,0,0,6"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource Stat_CurrentStreak}" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="{Binding LongestStreak}" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="{DynamicResource Stat_LongestStreak}" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="{Binding CompletionRate}" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="{DynamicResource Stat_CompletionRate}" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding AvgCompletionTime}" Style="{StaticResource StatValueStyle}"/>
                            <TextBlock Text="{DynamicResource Stat_AvgTime}" Style="{StaticResource StatLabelStyle}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- ── Charts row ───────────────────────────────────────────── -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 30-day daily chart -->
                    <Border Grid.Column="0"
                            Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <oxy:PlotView Model="{Binding DailyChart}"
                                          Height="220"
                                          Background="Transparent"/>
                        </StackPanel>
                    </Border>

                    <!-- Priority breakdown pie -->
                    <Border Grid.Column="2"
                            Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <oxy:PlotView Model="{Binding PriorityChart}"
                                          Height="220"
                                          Background="Transparent"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- ── Hourly chart + tags row ───────────────────────────── -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hourly bar chart -->
                    <Border Grid.Column="0"
                            Style="{StaticResource StatCardStyle}">
                        <oxy:PlotView Model="{Binding HourlyChart}"
                                      Height="200"
                                      Background="Transparent"/>
                    </Border>

                    <!-- Top tags -->
                    <Border Grid.Column="2"
                            Style="{StaticResource StatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Stat_TopTags}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding TopTags}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Item1}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                            <Border Grid.Column="1"
                                                    Background="{DynamicResource Primary50Brush}"
                                                    CornerRadius="8" Padding="8,2">
                                                <TextBlock Text="{Binding Item2}"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="{DynamicResource PrimaryBrush}"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <!-- Empty state -->
                            <TextBlock Text="{DynamicResource Stat_NoTags}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,16,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TopTags.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- Busy overlay -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#88FFFFFF"/>
            <ProgressBar Width="40" Height="40" IsIndeterminate="True"
                         VerticalAlignment="Center" HorizontalAlignment="Center"
                         Foreground="{DynamicResource PrimaryBrush}"/>
        </Grid>

    </Grid>
</UserControl>
