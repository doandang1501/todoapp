<UserControl x:Class="TodoApp.Views.LabelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             xmlns:conv="clr-namespace:TodoApp.Converters"
             d:DataContext="{d:DesignInstance Type=vm:LabelViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource AppBackground}">

    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexToBrush"/>

        <Style x:Key="SwatchBtnStyle" TargetType="Button">
            <Setter Property="Width"   Value="26"/>
            <Setter Property="Height"  Value="26"/>
            <Setter Property="Margin"  Value="3"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"  Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="13"
                                Background="{TemplateBinding Background}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="24,14">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="Label" Width="22" Height="22"
                                         Foreground="{DynamicResource PrimaryBrush}"
                                         VerticalAlignment="Center"/>
                <TextBlock Text="{DynamicResource Nav_Labels}"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           Margin="10,0,0,0" VerticalAlignment="Center"/>
                <Border Background="{DynamicResource Primary50Brush}"
                        CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding LabelCount}"
                               FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- ── Add-label form ─────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="24,16">
            <StackPanel>
                <TextBlock Text="{DynamicResource Label_AddNew}"
                           FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,10"/>

                <!-- Name TextBox + Add button -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding NewLabelName, UpdateSourceTrigger=PropertyChanged}"
                             Style="{DynamicResource RoundedTextBoxStyle}"
                             materialDesign:HintAssist.Hint="{DynamicResource Label_NameHint}">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding AddLabelCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="2"
                            Content="{DynamicResource Btn_Add}"
                            Style="{DynamicResource PrimaryButtonStyle}"
                            Command="{Binding AddLabelCommand}"
                            Padding="16,8"/>
                </Grid>

                <!-- Colour preview circle + label -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Border Width="28" Height="28" CornerRadius="14"
                            Background="{Binding NewLabelColor, Converter={StaticResource HexToBrush}}"
                            Margin="0,0,10,0" VerticalAlignment="Center">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.25"
                                              BlurRadius="6" ShadowDepth="1"/>
                        </Border.Effect>
                    </Border>
                    <TextBlock Text="{DynamicResource Label_ChooseColor}"
                               VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                </StackPanel>

                <!-- Colour swatches -->
                <ItemsControl ItemsSource="{x:Static vm:LabelViewModel.PresetColors}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource SwatchBtnStyle}"
                                    Background="{Binding Converter={StaticResource HexToBrush}}"
                                    Command="{Binding DataContext.SelectColorCommand,
                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- ── Label list ─────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="24,12">
            <StackPanel>

                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" Margin="0,48,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding LabelCount}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Kind="LabelOutline" Width="56" Height="56"
                                             Foreground="{DynamicResource DividerBrush}"
                                             HorizontalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Label_Empty}"
                               FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>

                <!-- Label rows -->
                <ItemsControl ItemsSource="{Binding Labels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource SurfaceBrush}"
                                    CornerRadius="8" Padding="14,10"
                                    Margin="0,0,0,6">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Ellipse Width="18" Height="18"
                                                 Fill="{Binding Color, Converter={StaticResource HexToBrush}}"
                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14" FontWeight="Medium"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   Margin="12,0,0,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Color}"
                                                   FontSize="11" FontFamily="Consolas"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <Button HorizontalAlignment="Right"
                                            Style="{DynamicResource IconButtonStyle}"
                                            Width="32" Height="32"
                                            Command="{Binding DataContext.DeleteLabelCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"
                                                                 Foreground="{DynamicResource ErrorBrush}"/>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
