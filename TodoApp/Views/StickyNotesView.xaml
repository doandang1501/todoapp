<UserControl x:Class="TodoApp.Views.StickyNotesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             xmlns:conv="clr-namespace:TodoApp.Converters"
             d:DataContext="{d:DesignInstance Type=vm:StickyNotesViewModel}"
             mc:Ignorable="d"
             Background="{DynamicResource AppBackground}">

    <UserControl.Resources>
        <conv:HexToBrushConverter x:Key="HexToBrush"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="24,14">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="NoteText" Width="22" Height="22"
                                             Foreground="{DynamicResource PrimaryBrush}"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="{DynamicResource Page_StickyNotes}"
                               FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource Primary50Brush}"
                            CornerRadius="10" Padding="8,2" Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding NoteCount}"
                                   FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryBrush}"/>
                    </Border>
                </StackPanel>

                <Button HorizontalAlignment="Right"
                        Style="{DynamicResource MaterialDesignRaisedButton}"
                        Background="{DynamicResource PrimaryBrush}"
                        Command="{Binding CreateNoteCommand}"
                        Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource StickyNotes_NewNote}" Margin="6,0,0,0"
                                   VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── Notes grid ─────────────────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid Margin="20,16,20,24">

                <!-- Empty state -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="0,60,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding NoteCount}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Kind="NoteTextOutline"
                                             Width="64" Height="64"
                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                             HorizontalAlignment="Center"
                                             Opacity="0.4"/>
                    <TextBlock Text="{DynamicResource StickyNotes_Empty}"
                               FontSize="16" FontWeight="Medium"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,6"/>
                    <TextBlock Text="{DynamicResource StickyNotes_EmptyHint}"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Opacity="0.7"/>
                </StackPanel>

                <!-- Notes wrap panel -->
                <ItemsControl ItemsSource="{Binding Notes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- Card -->
                            <Border Width="220" Height="180"
                                    CornerRadius="8"
                                    Margin="0,0,16,16"
                                    Cursor="Hand"
                                    Background="{Binding BackgroundColor, Converter={StaticResource HexToBrush}}">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.12"
                                                      BlurRadius="10" ShadowDepth="2" Direction="270"/>
                                </Border.Effect>
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.OpenNoteCommand,
                                                            RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="32"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header bar (semi-transparent overlay for darker look) -->
                                    <Border Grid.Row="0" CornerRadius="8,8,0,0"
                                            Background="#1A000000">
                                        <Grid Margin="10,0">
                                            <materialDesign:PackIcon Kind="NoteText"
                                                                     Width="14" Height="14"
                                                                     Foreground="#5D4037"
                                                                     VerticalAlignment="Center"
                                                                     HorizontalAlignment="Left"/>
                                            <Button HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Width="20" Height="20"
                                                    Style="{DynamicResource IconButtonStyle}"
                                                    ToolTip="Delete note"
                                                    Command="{Binding DataContext.DeleteNoteCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Close"
                                                                         Width="11" Height="11"
                                                                         Foreground="#5D4037"/>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Content preview -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Content}"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="10,8,10,4"
                                               FontSize="12"
                                               Foreground="#3E2723"
                                               MaxHeight="96"
                                               VerticalAlignment="Top"/>

                                    <!-- Date footer -->
                                    <TextBlock Grid.Row="2"
                                               Margin="10,0,10,8"
                                               FontSize="10"
                                               Foreground="#795548"
                                               Opacity="0.8"
                                               HorizontalAlignment="Right"
                                               Text="{Binding CreatedAt, StringFormat={}{0:MMM d}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <!-- Busy overlay -->
        <Grid Grid.Row="1">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#88FFFFFF"/>
            <ProgressBar Width="40" Height="40" IsIndeterminate="True"
                         VerticalAlignment="Center" HorizontalAlignment="Center"
                         Foreground="{DynamicResource PrimaryBrush}"/>
        </Grid>
    </Grid>
</UserControl>
