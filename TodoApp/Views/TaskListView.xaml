<UserControl x:Class="TodoApp.Views.TaskListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:vm="clr-namespace:TodoApp.ViewModels"
             xmlns:controls="clr-namespace:TodoApp.Controls"
             xmlns:behaviors="clr-namespace:TodoApp.Behaviors"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             d:DataContext="{d:DesignInstance Type=vm:TaskListViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{DynamicResource AppBackground}">

    <UserControl.Resources>

        <!-- Priority colour map -->
        <SolidColorBrush x:Key="PrioLowColor"      Color="#4CAF50"/>
        <SolidColorBrush x:Key="PrioMediumColor"   Color="#FF9800"/>
        <SolidColorBrush x:Key="PrioHighColor"     Color="#F44336"/>
        <SolidColorBrush x:Key="PrioCriticalColor" Color="#9C27B0"/>

        <!-- Filter chip style -->
        <Style x:Key="FilterChipStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                CornerRadius="16" Padding="14,6"
                                Background="Transparent"
                                BorderBrush="{DynamicResource DividerBrush}"
                                BorderThickness="1.5" Cursor="Hand">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource PrimaryBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource PrimaryBrush}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource PrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>

        <!-- Sort button style -->
        <Style x:Key="SortButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="Transparent"/>
            <Setter Property="BorderBrush"  Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground"   Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="FontWeight"   Value="Medium"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Padding"      Value="10,5"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="4"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource Primary50Brush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Priority left-bar colour converter via Style -->
        <Style x:Key="PrioBarStyle" TargetType="Border">
            <Setter Property="Width"        Value="4"/>
            <Setter Property="CornerRadius" Value="2,0,0,2"/>
            <Setter Property="Background"   Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Filter bar -->
            <RowDefinition Height="Auto"/>  <!-- Sort bar -->
            <RowDefinition Height="*"/>     <!-- Task list -->
        </Grid.RowDefinitions>

        <!-- ── Header ────────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title + count badges -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{DynamicResource Task_MyTasks}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <!-- Pending badge -->
                    <Border Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="10" Padding="8,3"
                            Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding PendingCount}"
                                   FontSize="11" FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                    <!-- Overdue badge -->
                    <Border CornerRadius="10" Padding="8,3"
                            Margin="6,0,0,0" VerticalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OverdueCount}" Value="0">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AlertCircle" Width="11" Height="11"
                                                     Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding OverdueCount}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="White" Margin="3,0,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Search box -->
                <TextBox Grid.Column="1"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{DynamicResource RoundedTextBoxStyle}"
                         Width="220"
                         materialDesign:HintAssist.Hint="{DynamicResource Task_SearchPlaceholder}"
                         VerticalAlignment="Center"/>

                <!-- Add task button -->
                <Button Grid.Column="3"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding AddTaskCommand}"
                        Padding="16,8">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Plus" Width="18" Height="18"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource Task_NewTask}" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ── Filter chips ────────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                Background="{DynamicResource SurfaceBrush}"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource DividerBrush}"
                Padding="24,10">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="{DynamicResource Task_FilterAll}"     Style="{StaticResource FilterChipStyle}"
                             GroupName="Filter" IsChecked="True"
                             Command="{Binding SetFilterCommand}" CommandParameter="All"/>
                <RadioButton Content="{DynamicResource Task_FilterToday}"   Style="{StaticResource FilterChipStyle}"
                             GroupName="Filter"
                             Command="{Binding SetFilterCommand}" CommandParameter="Today"/>
                <RadioButton Content="{DynamicResource Task_FilterOverdue}" Style="{StaticResource FilterChipStyle}"
                             GroupName="Filter"
                             Command="{Binding SetFilterCommand}" CommandParameter="Overdue"/>
                <RadioButton Content="{DynamicResource Task_FilterPinned}"  Style="{StaticResource FilterChipStyle}"
                             GroupName="Filter"
                             Command="{Binding SetFilterCommand}" CommandParameter="Pinned"/>
                <RadioButton Content="{DynamicResource Task_FilterHigh}"    Style="{StaticResource FilterChipStyle}"
                             GroupName="Filter"
                             Command="{Binding SetFilterCommand}" CommandParameter="High"/>
                <RadioButton Content="{DynamicResource Task_FilterDone}"    Style="{StaticResource FilterChipStyle}"
                             GroupName="Filter"
                             Command="{Binding SetFilterCommand}" CommandParameter="Done"/>

                <!-- Summary counts -->
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12">
                        <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                        <Run Text="{DynamicResource Summary_Total}"/>
                        <Run Text="{Binding TodayCount, Mode=OneWay}"/>
                        <Run Text="{DynamicResource Summary_Today}"/>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Sort bar ────────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{DynamicResource AppBackground}"
                Padding="24,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource Task_SortBy}"
                           FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>
                <Button Style="{StaticResource SortButtonStyle}"
                        Content="{DynamicResource Task_SortPriority}"
                        Command="{Binding SetSortCommand}"
                        CommandParameter="Priority"/>
                <Button Style="{StaticResource SortButtonStyle}"
                        Content="{DynamicResource Task_SortDeadline}"
                        Command="{Binding SetSortCommand}"
                        CommandParameter="Deadline"/>
                <Button Style="{StaticResource SortButtonStyle}"
                        Content="{DynamicResource Task_SortCreated}"
                        Command="{Binding SetSortCommand}"
                        CommandParameter="Created"/>
                <Button Style="{StaticResource SortButtonStyle}"
                        Content="{DynamicResource Task_SortTitle}"
                        Command="{Binding SetSortCommand}"
                        CommandParameter="Title"/>
                <!-- Direction indicator -->
                <materialDesign:PackIcon VerticalAlignment="Center" Margin="4,0,0,0"
                                         Foreground="{DynamicResource PrimaryBrush}">
                    <materialDesign:PackIcon.Style>
                        <Style TargetType="materialDesign:PackIcon">
                            <Setter Property="Kind" Value="SortAscending"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SortAscending}" Value="False">
                                    <Setter Property="Kind" Value="SortDescending"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </materialDesign:PackIcon.Style>
                </materialDesign:PackIcon>
                <TextBlock Text="{Binding ActiveSortField}"
                           FontSize="12" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryBrush}"
                           VerticalAlignment="Center"
                           Margin="4,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- ── Task list ──────────────────────────────────────────────────── -->
        <Grid Grid.Row="3">

            <!-- Empty state -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EmptyStateMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <materialDesign:PackIcon Kind="CheckAll"
                                         Width="56" Height="56"
                                         Foreground="{DynamicResource DividerBrush}"
                                         HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding EmptyStateMessage}"
                           FontSize="16"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
            </StackPanel>

            <!-- Task cards (ListBox lets the behavior reorder items via drag & drop) -->
            <ListBox ItemsSource="{Binding FilteredTasks}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="False"
                     SelectionMode="Single"
                     BorderThickness="0"
                     Background="Transparent"
                     Padding="0,0,4,0">

                <i:Interaction.Behaviors>
                    <behaviors:ListBoxReorderBehavior ReorderCommand="{Binding ReorderTaskCommand}"/>
                </i:Interaction.Behaviors>

                <!-- Strip ListBoxItem chrome so cards look identical to before -->
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding"                   Value="0"/>
                        <Setter Property="Margin"                    Value="20,0,20,0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="FocusVisualStyle"          Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:TaskRowViewModel}">
                            <Border x:Name="TaskCard"
                                    Margin="0,0,0,8"
                                    CornerRadius="8"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderThickness="1"
                                    BorderBrush="{DynamicResource DividerBrush}"
                                    Cursor="Hand">

                                <!-- Urgent / completed state -->
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background"  Value="{DynamicResource SurfaceBrush}"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource DividerBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUrgent}" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Opacity" Value="0.6"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <!-- Hover-reveal action panel animation -->
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="UIElement.MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ActionButtons"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="UIElement.MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="ActionButtons"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.12"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>

                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftDoubleClick"
                                                  Command="{Binding DataContext.EditTaskCommand,
                                                      RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="4"/>   <!-- Priority bar -->
                                        <ColumnDefinition Width="*"/>   <!-- Content -->
                                        <ColumnDefinition Width="100"/> <!-- Actions (fixed width) -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Priority colour bar -->
                                    <Border Grid.Column="0" CornerRadius="8,0,0,8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource PrioMediumColor}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                        <Setter Property="Background" Value="{StaticResource PrioLowColor}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Priority}" Value="High">
                                                        <Setter Property="Background" Value="{StaticResource PrioHighColor}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Priority}" Value="Critical">
                                                        <Setter Property="Background" Value="{StaticResource PrioCriticalColor}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <!-- Main content -->
                                    <Grid Grid.Column="1" Margin="12,12,8,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Row 0: Checkbox + Title + Pin icon -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <CheckBox Grid.Column="0"
                                                      Style="{StaticResource TodoCheckBoxStyle}"
                                                      IsChecked="{Binding IsCompleted, Mode=OneWay}"
                                                      Command="{Binding DataContext.ToggleCompleteCommand,
                                                          RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                      CommandParameter="{Binding}"/>

                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Title}"
                                                       FontSize="14" FontWeight="Medium"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       Margin="10,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Pin indicator -->
                                            <materialDesign:PackIcon Grid.Column="2"
                                                                     Kind="Pin"
                                                                     Width="14" Height="14"
                                                                     Foreground="{DynamicResource PrimaryBrush}"
                                                                     VerticalAlignment="Center"
                                                                     Margin="4,0,0,0">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Grid>

                                        <!-- Row 1: Description – markdown rendered -->
                                        <controls:MarkdownTextBlock Grid.Row="1"
                                                   MarkdownText="{Binding Description}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap"
                                                   MaxHeight="40"
                                                   TextTrimming="CharacterEllipsis"
                                                   Margin="40,4,0,0">
                                            <controls:MarkdownTextBlock.Style>
                                                <Style TargetType="controls:MarkdownTextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Description}" Value="">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </controls:MarkdownTextBlock.Style>
                                        </controls:MarkdownTextBlock>

                                        <!-- Row 2: meta row — deadline + tags + subtask progress -->
                                        <StackPanel Grid.Row="2" Orientation="Horizontal"
                                                    Margin="40,6,0,0" FlowDirection="LeftToRight">

                                            <!-- Deadline badge -->
                                            <Border CornerRadius="4" Padding="6,2"
                                                    Margin="0,0,8,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource Primary50Brush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DeadlineRelative}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsUrgent}" Value="True">
                                                                <Setter Property="Background" Value="#FFCC02"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Clock" Width="12" Height="12"
                                                                             VerticalAlignment="Center">
                                                        <materialDesign:PackIcon.Style>
                                                            <Style TargetType="materialDesign:PackIcon">
                                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </materialDesign:PackIcon.Style>
                                                    </materialDesign:PackIcon>
                                                    <TextBlock Text="{Binding DeadlineRelative}"
                                                               FontSize="11"
                                                               Margin="4,0,0,0"
                                                               VerticalAlignment="Center">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                                                        <Setter Property="Foreground" Value="White"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                            <!-- Tags -->
                                            <ItemsControl ItemsSource="{Binding Tags}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="{DynamicResource Primary100Brush}"
                                                                CornerRadius="4" Padding="6,2"
                                                                Margin="0,0,4,0">
                                                            <TextBlock Text="{Binding}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource PrimaryDarkBrush}"/>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Subtask progress -->
                                            <Border CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasSubTasks}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="CheckboxMultipleOutline"
                                                                             Width="12" Height="12"
                                                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                                                             VerticalAlignment="Center"/>
                                                    <TextBlock FontSize="11"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center"
                                                               Margin="4,0,0,0">
                                                        <Run Text="{Binding SubTaskDone, Mode=OneWay}"/>
                                                        <Run Text="/"/>
                                                        <Run Text="{Binding SubTaskCount, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>

                                        </StackPanel>

                                        <!-- Subtask progress bar -->
                                        <ProgressBar Grid.Row="2"
                                                     Value="{Binding Progress, Mode=OneWay}"
                                                     Minimum="0" Maximum="100"
                                                     Height="3"
                                                     Margin="40,4,0,0"
                                                     Foreground="{DynamicResource PrimaryBrush}"
                                                     Background="{DynamicResource DividerBrush}">
                                            <ProgressBar.Style>
                                                <Style TargetType="ProgressBar">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasSubTasks}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ProgressBar.Style>
                                        </ProgressBar>

                                    </Grid>

                                    <!-- Action buttons (hover-reveal, horizontal) -->
                                    <StackPanel x:Name="ActionButtons"
                                                Grid.Column="2"
                                                Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Opacity="0">

                                        <!-- Edit -->
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                Width="32" Height="32"
                                                ToolTip="{DynamicResource Task_Edit}"
                                                Command="{Binding DataContext.EditTaskCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="PencilOutline"
                                                                     Width="17" Height="17"
                                                                     Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Button>

                                        <!-- Pin / Unpin -->
                                        <Button Style="{StaticResource IconButtonStyle}"
                                                Width="32" Height="32"
                                                ToolTip="{DynamicResource Task_Pin}"
                                                Command="{Binding DataContext.TogglePinCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Width="17" Height="17">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Kind"       Value="BookmarkOutline"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                <Setter Property="Kind"       Value="Bookmark"/>
                                                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Button>

                                        <!-- Delete -->
                                        <Button Style="{StaticResource IconButtonDangerStyle}"
                                                Width="32" Height="32"
                                                ToolTip="{DynamicResource Task_Delete}"
                                                Command="{Binding DataContext.DeleteTaskCommand,
                                                    RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                CommandParameter="{Binding}">
                                            <materialDesign:PackIcon Kind="TrashCanOutline"
                                                                     Width="17" Height="17"
                                                                     Foreground="{DynamicResource ErrorBrush}"/>
                                        </Button>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Busy overlay -->
            <Grid>
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Background="#88FFFFFF"/>
                <ProgressBar Width="40" Height="40"
                             IsIndeterminate="True"
                             VerticalAlignment="Center"
                             HorizontalAlignment="Center"
                             Foreground="{DynamicResource PrimaryBrush}"/>
            </Grid>

        </Grid>
    </Grid>
</UserControl>
