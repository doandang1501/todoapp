<Window x:Class="TodoApp.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:TodoApp.ViewModels"
        d:DataContext="{d:DesignInstance Type=vm:ToastViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Width="360"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        TextElement.FontSize="13"
        FontFamily="{materialDesign:MaterialDesignFont}">

    <Window.RenderTransform>
        <TranslateTransform x:Name="SlideTransform" X="380"/>
    </Window.RenderTransform>

    <Border CornerRadius="10"
            Background="{DynamicResource SurfaceBrush}"
            BorderThickness="1"
            BorderBrush="{DynamicResource DividerBrush}">

        <!-- Drop-shadow effect -->
        <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.22"
                              BlurRadius="18" ShadowDepth="4" Direction="270"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Header -->
                <RowDefinition Height="Auto"/>  <!-- Body -->
                <RowDefinition Height="Auto"/>  <!-- Actions -->
                <RowDefinition Height="4"/>     <!-- Progress bar -->
            </Grid.RowDefinitions>

            <!-- â”€â”€ Header â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource PrimaryBrush}"
                    CornerRadius="10,10,0,0"
                    Padding="14,10">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- Timing icon -->
                        <materialDesign:PackIcon Kind="BellRing"
                                                 Width="18" Height="18"
                                                 Foreground="White"
                                                 VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TimingLabel}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="White"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Close (dismiss) X button -->
                    <Button HorizontalAlignment="Right"
                            Style="{DynamicResource IconButtonStyle}"
                            Width="24" Height="24"
                            Command="{Binding DismissCommand}"
                            ToolTip="Dismiss">
                        <materialDesign:PackIcon Kind="Close" Width="14" Height="14"
                                                 Foreground="White"/>
                    </Button>
                </Grid>
            </Border>

            <!-- â”€â”€ Body â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <StackPanel Grid.Row="1" Margin="14,12,14,8">

                <!-- Priority label -->
                <Border HorizontalAlignment="Left"
                        CornerRadius="4" Padding="6,2" Margin="0,0,0,6">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource Primary50Brush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding PriorityLabel}"
                               FontSize="11" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                                        <Setter Property="Foreground" Value="White"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <!-- Task title -->
                <TextBlock Text="{Binding TaskTitle}"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="320"/>

                <!-- Deadline -->
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DeadlineText}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <materialDesign:PackIcon Kind="Clock"
                                             Width="14" Height="14"
                                             Foreground="{DynamicResource TextSecondaryBrush}"
                                             VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DeadlineText}"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="5,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

            </StackPanel>

            <!-- â”€â”€ Action buttons â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <Grid Grid.Row="2" Margin="14,0,14,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="{DynamicResource Toast_Snooze10m}"
                        Style="{DynamicResource GhostButtonStyle}"
                        Command="{Binding Snooze10Command}"
                        FontSize="12" Padding="0,6"/>

                <Button Grid.Column="2"
                        Content="{DynamicResource Toast_Snooze1h}"
                        Style="{DynamicResource GhostButtonStyle}"
                        Command="{Binding Snooze1HrCommand}"
                        FontSize="12" Padding="0,6"/>

                <Button Grid.Column="4"
                        Content="{DynamicResource Toast_Dismiss}"
                        Style="{DynamicResource PrimaryButtonStyle}"
                        Command="{Binding DismissCommand}"
                        FontSize="12" Padding="14,6"/>
            </Grid>

            <!-- â”€â”€ Auto-dismiss progress bar â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€ -->
            <ProgressBar Grid.Row="3"
                         Value="{Binding DismissProgress}"
                         Minimum="0" Maximum="100"
                         Height="4"
                         Foreground="{DynamicResource PrimaryBrush}"
                         Background="{DynamicResource DividerBrush}">
                <ProgressBar.Style>
                    <Style TargetType="ProgressBar">
                        <Style.Resources>
                            <!-- Remove the animated glow overlay that obscures the bar -->
                            <Style TargetType="Border" x:Key="{x:Type Border}"/>
                        </Style.Resources>
                    </Style>
                </ProgressBar.Style>
            </ProgressBar>

        </Grid>
    </Border>
</Window>

