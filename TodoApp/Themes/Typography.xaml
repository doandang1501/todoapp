<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ══════════════════════════════════════════════════════════════════════
         FONT SIZE SCALE
    ════════════════════════════════════════════════════════════════════════ -->
    <sys:Double x:Key="FontSizeXS">10</sys:Double>
    <sys:Double x:Key="FontSizeSM">12</sys:Double>
    <sys:Double x:Key="FontSizeMD">14</sys:Double>
    <sys:Double x:Key="FontSizeLG">16</sys:Double>
    <sys:Double x:Key="FontSizeXL">20</sys:Double>
    <sys:Double x:Key="FontSizeXXL">24</sys:Double>
    <sys:Double x:Key="FontSizeDisplay">32</sys:Double>

    <!-- ══════════════════════════════════════════════════════════════════════
         TEXT STYLES
    ════════════════════════════════════════════════════════════════════════ -->

    <Style x:Key="TextDisplayStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeDisplay}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="LineHeight" Value="40"/>
    </Style>

    <Style x:Key="TextHeadlineLargeStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeXXL}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="TextHeadlineMediumStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeXL}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="TextTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeLG}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
    </Style>

    <Style x:Key="TextBodyStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeMD}"/>
        <Setter Property="FontWeight" Value="Regular"/>
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="TextBodySecondaryStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeMD}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="TextCaptionStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeSM}"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>

    <Style x:Key="TextLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize"   Value="{StaticResource FontSizeXS}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
    </Style>

    <!-- Section header (all-caps label with spacing) -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock"
           BasedOn="{StaticResource TextLabelStyle}">
        <Setter Property="Margin"  Value="8,8,0,4"/>
        <Setter Property="Opacity" Value="0.7"/>
    </Style>

</ResourceDictionary>
