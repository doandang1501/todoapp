<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ══════════════════════════════════════════════════════════════════════
         EASING FUNCTIONS  (reusable across all animations)
    ════════════════════════════════════════════════════════════════════════ -->

    <CubicEase x:Key="EaseOut"    EasingMode="EaseOut"/>
    <CubicEase x:Key="EaseIn"     EasingMode="EaseIn"/>
    <CubicEase x:Key="EaseInOut"  EasingMode="EaseInOut"/>
    <BackEase  x:Key="EaseSpring" EasingMode="EaseOut" Amplitude="0.3"/>

    <!-- ══════════════════════════════════════════════════════════════════════
         FADE IN  (used on page transitions and card appearances)
    ════════════════════════════════════════════════════════════════════════ -->
    <Storyboard x:Key="FadeInStoryboard">
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.25"
            EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <!-- ══════════════════════════════════════════════════════════════════════
         FADE OUT
    ════════════════════════════════════════════════════════════════════════ -->
    <Storyboard x:Key="FadeOutStoryboard">
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="1" To="0"
            Duration="0:0:0.20"
            EasingFunction="{StaticResource EaseIn}"/>
    </Storyboard>

    <!-- ══════════════════════════════════════════════════════════════════════
         SLIDE IN FROM BOTTOM  (toast notifications, quick panel)
    ════════════════════════════════════════════════════════════════════════ -->
    <Storyboard x:Key="SlideInFromBottomStoryboard">
        <DoubleAnimation
            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
            From="40" To="0"
            Duration="0:0:0.30"
            EasingFunction="{StaticResource EaseOut}"/>
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.25"
            EasingFunction="{StaticResource EaseOut}"/>
    </Storyboard>

    <!-- ══════════════════════════════════════════════════════════════════════
         SLIDE OUT TO BOTTOM  (toast dismiss)
    ════════════════════════════════════════════════════════════════════════ -->
    <Storyboard x:Key="SlideOutToBottomStoryboard">
        <DoubleAnimation
            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
            From="0" To="40"
            Duration="0:0:0.25"
            EasingFunction="{StaticResource EaseIn}"/>
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="1" To="0"
            Duration="0:0:0.20"
            EasingFunction="{StaticResource EaseIn}"/>
    </Storyboard>

    <!-- ══════════════════════════════════════════════════════════════════════
         SCALE POP  (card hover, task completion)
    ════════════════════════════════════════════════════════════════════════ -->
    <Storyboard x:Key="ScalePopStoryboard">
        <DoubleAnimationUsingKeyFrames
            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)">
            <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="1.0"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.10" Value="1.08"
                                  EasingFunction="{StaticResource EaseOut}"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="1.0"
                                  EasingFunction="{StaticResource EaseSpring}"/>
        </DoubleAnimationUsingKeyFrames>
        <DoubleAnimationUsingKeyFrames
            Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)">
            <EasingDoubleKeyFrame KeyTime="0:0:0.0"  Value="1.0"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.10" Value="1.08"
                                  EasingFunction="{StaticResource EaseOut}"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.22" Value="1.0"
                                  EasingFunction="{StaticResource EaseSpring}"/>
        </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <!-- ══════════════════════════════════════════════════════════════════════
         TICK (checkbox completion — draws a checkmark path)
         Animate StrokeDashOffset from full length to 0.
         Target: a Path with StrokeDashArray set to path length.
    ════════════════════════════════════════════════════════════════════════ -->
    <Storyboard x:Key="TickDrawStoryboard">
        <DoubleAnimation
            Storyboard.TargetProperty="StrokeDashOffset"
            From="30" To="0"
            Duration="0:0:0.35"
            EasingFunction="{StaticResource EaseOut}"/>
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="0" To="1"
            Duration="0:0:0.15"/>
    </Storyboard>

    <!-- ══════════════════════════════════════════════════════════════════════
         SHAKE  (validation error feedback)
    ════════════════════════════════════════════════════════════════════════ -->
    <Storyboard x:Key="ShakeStoryboard">
        <DoubleAnimationUsingKeyFrames
            Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)">
            <EasingDoubleKeyFrame KeyTime="0:0:0.00" Value="0"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.06" Value="-8"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.12" Value="8"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.18" Value="-6"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.24" Value="6"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.30" Value="-4"/>
            <EasingDoubleKeyFrame KeyTime="0:0:0.36" Value="0"/>
        </DoubleAnimationUsingKeyFrames>
    </Storyboard>

    <!-- ══════════════════════════════════════════════════════════════════════
         PULSE  (notification badge, overdue indicator)
    ════════════════════════════════════════════════════════════════════════ -->
    <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever"
                AutoReverse="True">
        <DoubleAnimation
            Storyboard.TargetProperty="Opacity"
            From="1.0" To="0.4"
            Duration="0:0:0.8"
            EasingFunction="{StaticResource EaseInOut}"/>
    </Storyboard>

</ResourceDictionary>
